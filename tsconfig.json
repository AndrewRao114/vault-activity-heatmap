{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"moduleResolution": "node",
		"importHelpers": false,
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ES2020"]
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
